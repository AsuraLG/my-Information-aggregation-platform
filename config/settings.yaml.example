# 全局设置示例 — 复制为 settings.yaml 并按需修改
# AI 参数优先级：settings.yaml 配置 > 环境变量（INFO_AGG_AI_*）

ai:
  # provider_type: "anthropic"          # 必填；不填则读取 INFO_AGG_AI_PROVIDER_TYPE 环境变量，可选 anthropic / openai
  # model: "claude-3-5-haiku-20241022"  # 必填；不填则读取 INFO_AGG_AI_MODEL 环境变量
  max_tokens: 1024                       # 可选；不填则读取 INFO_AGG_AI_MAX_TOKENS 环境变量，默认 1024
  # api_key: "sk-..."                   # 必填；不填则读取 INFO_AGG_AI_API_KEY 环境变量
  # base_url: "https://..."             # 可选；不填则读取 INFO_AGG_AI_BASE_URL 环境变量（自定义端点/代理）

storage:
  data_dir: "data"

publish:
  output_dir: "output"
  github_remote: "origin"
  github_branch: "gh-pages"
  site_title: "我的信息聚合"
  site_description: "个人信息聚合平台，每日自动更新"
